{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/ai",        "destination": "/api/ai.py" },
    { "source": "/api/prospects", "destination": "/api/prospects.py" },
    { "source": "/api/sheets",    "destination": "/api/sheets.py" },
    { "source": "/api/(.*)",      "destination": "/api/sheets.py" },
    { "source": "/(.*)",          "destination": "/index.html" }
  ]
}
