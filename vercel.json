{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/sheets.py": { "runtime": "python3.9" },
    "api/ai.py":     { "runtime": "python3.9" }
  },
  "rewrites": [
    { "source": "/api/ai",   "destination": "/api/ai.py" },
    { "source": "/api/(.*)", "destination": "/api/sheets.py" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}