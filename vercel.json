{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/sheets.py": { "maxDuration": 30 },
    "api/ai.py":     { "maxDuration": 30 },
    "api/prospects.py": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/ai",        "destination": "/api/ai.py" },
    { "source": "/api/prospects", "destination": "/api/prospects.py" },
    { "source": "/api/(.*)",      "destination": "/api/sheets.py" },
    { "source": "/(.*)",          "destination": "/index.html" }
  ]
}
