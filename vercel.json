{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/sheets.py": { "runtime": "python3.12", "maxDuration": 15 },
    "api/ai.py":     { "runtime": "python3.12", "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/ai",       "destination": "/api/ai.py" },
    { "source": "/api/(.*)",     "destination": "/api/sheets.py" },
    { "source": "/(.*)",         "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Api-Key" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
